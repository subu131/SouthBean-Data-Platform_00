													"value": {
														"value": "@if(\n    empty(activity('Get_max_watermark_value').output.value[0].NewWatermarkValue),\n    '',\n    formatDateTime(activity('Get_max_watermark_value').output.value[0].NewWatermarkValue, 'yyyy-MM-ddTHH:mm:ss.fffffff')\n)\n",
