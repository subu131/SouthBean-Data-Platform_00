											"timeout": "0.12:00:00",
											"retry": 0,
											"retryIntervalInSeconds": 30,
											"secureOutput": false,
											"secureInput": false
										},
										"userProperties": [],
										"typeProperties": {
											"source": {
												"type": "PostgreSqlV2Source",
												"query": {
													"value": "SELECT * FROM @{item().SourceSchema}.@{item().TableName} \nWHERE @{item().WatermarkColumn} > DATEADD(day, -1, '@{item().LastWatermarkValue}')\n",
													"type": "Expression"
												},
												"queryTimeout": "02:00:00"
											},
											"sink": {
												"type": "ParquetSink",
												"storeSettings": {
													"type": "AzureBlobFSWriteSettings"
												},
												"formatSettings": {
													"type": "ParquetWriteSettings"
												}
											},
											"enableStaging": false,
											"translator": {
												"type": "TabularTranslator",
												"typeConversion": true,
												"typeConversionSettings": {
													"allowDataTruncation": true,
													"treatBooleanAsNumber": false
												}
											}
										},
										"inputs": [
											{
												"referenceName": "DS_NeonPostgress",
												"type": "DatasetReference"
											}
										],
										"outputs": [
											{
												"referenceName": "DS_Adlsgen2",
												"type": "DatasetReference",
												"parameters": {
													"bronze_path": "@concat('bronze/',item().BronzeFolder)",
													"table_name": "@item().TableName",
													"p_year": "@formatDateTime(utcNow(), 'yyyy')",
													"p_month": "@formatDateTime(utcNow(), 'MM')",
													"p_day": "@formatDateTime(utcNow(), 'dd')"
												}
											}
										]
									},
