										"typeProperties": {
											"source": {
												"type": "PostgreSqlV2Source",
												"query": {
													"value": "select max(@{item().WatermarkColumn}) as NewWatermarkValue\nfrom @{item().SourceSchema}.@{item().TableName}\nwhere @{item().WatermarkColumn} > '@{item().LastWatermarkValue}' :: timestamp",
													"type": "Expression"
												},
												"queryTimeout": "02:00:00"
